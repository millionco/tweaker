{
  "name": "@ben-million/tweaker",
  "version": "0.9.2",
  "description": "A dev tool for dragging page elements and generating DOM repositioning prompts",
  "keywords": [
    "dev-tools",
    "dom",
    "drag-and-drop",
    "layout",
    "prompt",
    "react"
  ],
  "homepage": "https://github.com/millionco/tweaker#readme",
  "bugs": {
    "url": "https://github.com/millionco/tweaker/issues"
  },
  "license": "MIT",
  "author": "Million Co.",
  "repository": {
    "type": "git",
    "url": "https://github.com/millionco/tweaker.git",
    "directory": "packages/tweaker"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "rm -rf dist && NODE_ENV=production tsdown",
    "test": "vitest run --environment jsdom",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsdown": "^0.20.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
